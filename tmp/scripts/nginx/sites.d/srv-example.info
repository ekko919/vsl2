# config explanation: 
# requests for `test-load-balancer.example.dev` will be proxied to the `upstream` load balancer named `example`
# the load balancer will balance between all the servers listed in the `upstream` block (../upstream.example) in a round robin fashion
server {
    include /etc/nginx/commmon.d/http.conf;
	include /etc/nginx/common.d/https.conf;

	server_name  test-load-balancer.example.dev;

    #charset koi8-r;
    access_log  /var/log/nginx/example.access.log  main;

    location / {
        # we use `example` here because that's what we've set as the name in the corresponding `upstream` block in ../upstream.example
        proxy_pass http://example;
    }
}

